prefix_rule(pattern=["npx", "-y", "react-doctor@latest"], decision="allow")
prefix_rule(pattern=["pnpm", "e2e:local"], decision="allow")
prefix_rule(pattern=["pnpm", "validate"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "CI=true pnpm install --ignore-scripts --no-frozen-lockfile"], decision="allow")
prefix_rule(pattern=["pnpm", "test"], decision="allow")
prefix_rule(pattern=["gh", "pr", "view"], decision="allow")
prefix_rule(pattern=["gh", "pr", "edit"], decision="allow")
prefix_rule(pattern=["pnpm", "--filter", "@vpt/web", "build"], decision="allow")
prefix_rule(pattern=["pnpm", "--filter", "@sweco/sanity", "sanity:typegen"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "SANITY_TYPEGEN_TARGET=germany pnpm --filter @sweco/sanity sanity:typegen"], decision="allow")
prefix_rule(pattern=["pnpm", "build"], decision="allow")
prefix_rule(pattern=["rm", "-f", "apps/germany/.next/lock"], decision="allow")
prefix_rule(pattern=["pnpm", "--filter", "@retur/sanity", "type-check"], decision="allow")
prefix_rule(pattern=["pnpm", "--filter", "@sweco/sanity", "type-check"], decision="allow")
